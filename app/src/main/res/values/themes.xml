<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.HRCallTracker" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryDark">@color/primary_blue</item>
        <item name="colorAccent">@color/status_green</item>
        <item name="android:statusBarColor">@color/bg_light_gray</item>
        <item name="android:windowBackground">@color/surface_white</item>
    </style>

    <style name="Theme.HRCallTracker.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/surface_white</item>
        <item name="android:statusBarColor">@color/surface_white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@color/surface_white</item>
    </style>
</resources>
