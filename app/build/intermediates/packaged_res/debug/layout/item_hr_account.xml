<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/bg_slate_800"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/glass_card"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvHrName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="HR Name"
                android:textColor="@color/text_slate_50"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <ImageView
                android:id="@+id/btnEdit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/text_slate_400" />

            <ImageView
                android:id="@+id/btnDelete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/rose_500" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvEmployeeId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Employee ID: HR001"
            android:textColor="@color/indigo_500"
            android:textSize="12sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Username: rahul_hr"
            android:textColor="@color/text_slate_400"
            android:textSize="13sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@color/border_slate" />

        <TextView
            android:id="@+id/tvScriptUrl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:ellipsize="middle"
            android:maxLines="1"
            android:text="https://script.google.com/..."
            android:textColor="@color/text_slate_400"
            android:textSize="11sp"
            android:alpha="0.7" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
